# Example: Generate Contribution Snake Animation
#
# This workflow generates an animated snake eating your GitHub contributions
# and saves it to your profile repository.
#
# To use:
# 1. Copy to .github/workflows/snake-animation.yml
# 2. The snake SVG will be generated at: github-contribution-grid-snake.svg
# 3. Reference it in your README:
#    ![Snake animation](https://github.com/DenWin/DenWin/blob/output/github-contribution-grid-snake.svg)
# 4. Make sure you have an 'output' branch or adjust branch name

name: Generate Snake Animation

on:
  # Run automatically every 12 hours
  schedule:
    - cron: "0 */12 * * *"
  
  # Allow manual trigger
  workflow_dispatch:
  
  # Run on every push to main
  push:
    branches:
      - main

jobs:
  generate:
    runs-on: ubuntu-latest
    timeout-minutes: 10
    
    steps:
      # Checkout the repository
      - name: Checkout
        uses: actions/checkout@v3
      
      # Generate the snake animation
      - name: Generate Snake
        uses: Platane/snk/svg-only@v3
        with:
          github_user_name: ${{ github.repository_owner }}
          outputs: |
            dist/github-contribution-grid-snake.svg
            dist/github-contribution-grid-snake-dark.svg?palette=github-dark
        
      # Push the generated files to output branch
      - name: Push to output branch
        uses: crazy-max/ghaction-github-pages@v3
        with:
          target_branch: output
          build_dir: dist
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

# Note: This requires creating an 'output' branch in your repository
# You can create it with: git checkout -b output && git push origin output
